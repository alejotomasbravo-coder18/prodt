# ── Supabase ───────────────────────────────────────────────────────────────────
# Obtenés estos valores en: https://supabase.com/dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ⚠ NUNCA exponer en el cliente — solo en Server Components y API routes
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── API-Football ───────────────────────────────────────────────────────────────
# Gratis en: https://www.api-football.com (100 req/día en el plan gratuito)

API_FOOTBALL_KEY=your_api_football_key_here

# ── Seguridad ──────────────────────────────────────────────────────────────────
# Cadena aleatoria para proteger los API routes de cron y administración
# Generá una con: openssl rand -base64 32

CRON_SECRET=your_random_secret_here

# ── URLs ────────────────────────────────────────────────────────────────────────
# Solo en producción; en dev Next.js lo detecta automáticamente

# NEXT_PUBLIC_SITE_URL=https://prodt.vercel.app
